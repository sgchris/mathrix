  "difficulty": "hard",
  "instructions": "Calculate the percentage increase.",
  "question": {
    "text": "A value increases from 160 to 195. What is the percentage increase?",
    "mathExpression": [
      "$$ \\text{Increase from } 160 \\text{ to } 195 $$"
    ]
  },
  "inputs": [
    {
      "name": "increase",
      "label": "Percentage Increase (%):",
      "inputType": "number",
      "correctAnswer": "22"
    }
  ],
  "hints": [
    "Find the absolute difference.",
    "Divide the difference by the original value and multiply by 100."
  ],
  "explanation": {
    "steps": [
      "1. Find the difference: $$ 195 - 160 = 35 $$.",
      "2. Divide by original: $$ \\frac{35}{160} $$.",
      "3. Convert to percentage: $$ (\\frac{35}{160}) \\times 100 \\approx 22\\% $$."
    ]
  }
}