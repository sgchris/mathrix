{
  "id": "percentages-medium-005",
  "topicId": "percentages",
  "topicName": "Percentages",
  "difficulty": "medium",
  "instructions": "Calculate the percentage increase.",
  "question": {
    "text": "A product's price increased from $80 to $100. What is the percentage increase?",
    "mathExpression": [
      "$$ \\text{Old price: } \\$80 \\quad \\text{New price: } \\$100 $$"
    ]
  },
  "inputs": [
    {
      "name": "percentageIncrease",
      "label": "Percentage increase (%) =",
      "inputType": "number",
      "correctAnswer": "25"
    }
  ],
  "hints": [
    "Percentage increase is calculated using the formula: (new value − old value) ÷ old value × 100.",
    "The increase in price is $20. Divide 20 by the original price ($80), then multiply by 100."
  ],
  "explanation": {
    "steps": [
      "1. Find the amount of increase: $$ 100 - 80 = 20 $$.",
      "2. Use the percentage increase formula: $$ \\frac{\\text{increase}}{\\text{original}} \\times 100 $$.",
      "3. Substitute: $$ \\frac{20}{80} \\times 100 $$.",
      "4. Simplify: $$ \\frac{20}{80} = 0.25 $$, then $$ 0.25 \\times 100 = 25\\% $$."
    ]
  }
}
