  "topicName": "Percentages",
  "difficulty": "hard",
  "instructions": "Calculate the percentage increase.",
  "question": {
    "text": "A value increases from 170 to 210. What is the percentage increase?",
    "mathExpression": [
      "$$ \\text{Increase from } 170 \\text{ to } 210 $$"
    ]
  },
  "inputs": [
    {
      "name": "increase",
      "label": "Percentage Increase (%):",
      "inputType": "number",
      "correctAnswer": "24"
    }
  ],
  "hints": [
    "Find the absolute difference.",
    "Divide the difference by the original value and multiply by 100."
  ],
  "explanation": {
    "steps": [
      "1. Find the difference: $$ 210 - 170 = 40 $$.",
      "2. Divide by original: $$ \\frac{40}{170} $$.",
      "3. Convert to percentage: $$ (\\frac{40}{170}) \\times 100 \\approx 24\\% $$."
    ]
  }
}